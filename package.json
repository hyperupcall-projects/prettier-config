{
	"name": "@hyperupcall/prettier-config",
	"version": "0.11.0",
	"type": "module",
	"description": "Edwin's Prettier configuration.",
	"repository": {
		"type": "git",
		"url": "https://github.com/hyperupcall-projects/prettier-config"
	},
	"bugs": {
		"url": "https://github.com/hyperupcall-projects/prettier-config/issues"
	},
	"author": "Edwin Kofler <edwin@kofler.dev> (https://edwinkofler.com)",
	"license": "MPL-2.0",
	"private": false,
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"types": "./index.d.ts",
	"scripts": {
		"format": "prettier --check --ignore-unknown .",
		"format:fix": "prettier --write --ignore-unknown .",
		"format:lefthook": "prettier --write --ignore-unknown",
		"lint": "hyperupcall-scripts-nodejs lint",
		"typecheck": "tsc --project ./jsconfig.json"
	},
	"dependencies": {
		"@hyperupcall/config-utils": "^0.5.0"
	},
	"devDependencies": {
		"@hyperupcall/scripts-nodejs": "0.9.0",
		"@types/node": "^25.0.6",
		"prettier": "^3.7.4",
		"prettier-plugin-pkg": "^0.21.2",
		"typescript": "^5.9.3"
	},
	"markdownlint-cli2": {
		"extends": "./node_modules/@hyperupcall/markdownlint-config/.markdownlint.json"
	},
	"prettier": "./index.js"
}
